@{
    ViewData["Title"] = "Quan Ly Chi Tieu KPI";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="fas fa-cog me-2 text-primary"></i>Quan Ly Chi Tieu KPI
    </h5>
    <div class="d-flex gap-2">
        <a href="/KPI/Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay Lai
        </a>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalThem">
            <i class="fas fa-plus me-1"></i>Them Chi Tieu
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">#</th>
                    <th>Ten Chi Tieu</th>
                    <th>Danh Muc</th>
                    <th>Don Vi</th>
                    <th>Muc Tieu Mac Dinh</th>
                    <th>Trong So</th>
                    <th class="text-center">Thao Tac</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int stt = 1;
                    foreach (var ct in ViewBag.DsChiTieuKPI)
                    {
                        <tr>
                            <td class="ps-3">@stt</td>
                            <td class="fw-semibold">@ct.TenKPI</td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @ct.DanhMucKPI?.TenDanhMuc
                                </span>
                            </td>
                            <td>@(ct.DonVi ?? "—")</td>
                            <td>@ct.GiaTriMucTieu</td>
                            <td>@ct.TrongSo%</td>
                            <td class="text-center">
                                <form method="post" action="/KPI/XoaChiTieu" class="d-inline"
                                      onsubmit="return confirm('Xoa chi tieu nay?')">
                                    <input type="hidden" name="id" value="@ct.MaKPI" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        stt++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Them Chi Tieu -->
<div class="modal fade" id="modalThem" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-plus me-2"></i>Them Chi Tieu KPI Moi
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/KPI/ThemChiTieu">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ten Chi Tieu <span class="text-danger">*</span></label>
                        <input type="text" name="tenKPI" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Danh Muc <span class="text-danger">*</span></label>
                        <select name="maDanhMuc" class="form-select" required>
                            <option value="">-- Chon danh muc --</option>
                            @foreach (var dm in ViewBag.DsDanhMucKPI)
                            {
                                <option value="@dm.MaDanhMuc">@dm.TenDanhMuc</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Don Vi</label>
                            <input type="text" name="donVi" class="form-control"
                                   placeholder="%, don, trieu..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Muc Tieu Mac Dinh</label>
                            <input type="number" name="giaTriMucTieu" class="form-control"
                                   step="0.1" min="0" value="100" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Trong So (%)</label>
                            <input type="number" name="trongSo" class="form-control"
                                   step="0.1" min="0" max="100" value="10" />
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label fw-semibold">Mo Ta</label>
                        <textarea name="moTa" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Luu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>