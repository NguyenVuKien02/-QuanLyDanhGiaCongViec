@{
    ViewData["Title"] = "Quản Lý Công Việc";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="fas fa-tasks me-2 text-primary"></i>Quản Lý Công Việc
    </h5>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalThem">
            <i class="fas fa-plus me-1"></i>Giao Công Việc
        </button>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Thống kê nhanh -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-secondary">@ViewBag.ChuaBatDau</div>
            <div class="small text-muted">Chưa Bắt Đầu</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.DangLam</div>
            <div class="small text-muted">Đang Làm</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">@ViewBag.HoanThanh</div>
            <div class="small text-muted">Hoàn Thành</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-danger">@ViewBag.HuyBo</div>
            <div class="small text-muted">Huỷ Bỏ</div>
        </div>
    </div>
</div>

<!-- Bộ lọc -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Tìm Kiếm</label>
                <input type="text" name="tuKhoa" class="form-control"
                       placeholder="Tên công việc, tên người thực hiện..."
                       value="@ViewBag.TuKhoa" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Tháng</label>
                <select name="thang" class="form-select">
                    <option value="0">-- Tất cả --</option>
                    @for (int i = 1; i <= 12; i++)
                    {
                        if (ViewBag.ThangFilter == i)
                        {
                            <option value="@i" selected>Tháng @i</option>
                        }
                        else
                        {
                            <option value="@i">Tháng @i</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Năm</label>
                <select name="nam" class="form-select">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                    {
                        if (ViewBag.NamFilter == y)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Trạng Thái</label>
                <select name="trangThai" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var tt in new[] {
                    new { Val = "ChuaBatDau", Ten = "Chưa Bắt Đầu" },
                    new { Val = "DangLam",    Ten = "Đang Làm" },
                    new { Val = "HoanThanh",  Ten = "Hoàn Thành" },
                    new { Val = "HuyBo",      Ten = "Huỷ Bỏ" }
                    })
                    {
                        if (ViewBag.TrangThaiFilter == tt.Val)
                        {
                            <option value="@tt.Val" selected>@tt.Ten</option>
                        }
                        else
                        {
                            <option value="@tt.Val">@tt.Ten</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search"></i>
                </button>
            </div>
            <div class="col-md-1">
                <a href="/CongViec/Index" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-redo"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Kanban Board -->
<div class="row g-3">
    @{
        var chuaBatDauList = ViewBag.ChuaBatDauList as List<QuanLyDanhGiaCongViec.Models.CongViec>;
        var dangLamList = ViewBag.DangLamList as List<QuanLyDanhGiaCongViec.Models.CongViec>;
        var hoanThanhList = ViewBag.HoanThanhList as List<QuanLyDanhGiaCongViec.Models.CongViec>;
        var huyBoList = ViewBag.HuyBoList as List<QuanLyDanhGiaCongViec.Models.CongViec>;

        string queryStr = $"tuKhoa={ViewBag.TuKhoa}&thang={ViewBag.ThangFilter}&nam={ViewBag.NamFilter}&trangThai={ViewBag.TrangThaiFilter}";
    }

    <!-- Cột Chưa Bắt Đầu -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-secondary text-white fw-semibold">
                <i class="fas fa-circle me-2"></i>Chưa Bắt Đầu
                <span class="badge bg-white text-secondary float-end">@ViewBag.ChuaBatDau</span>
            </div>
            <div class="card-body p-2" style="min-height:300px">
                @foreach (var cv in chuaBatDauList ?? new())
                {
                    @await Html.PartialAsync("_CongViecCard", cv)
                }
            </div>
            @if (ViewBag.TongTrangCBD > 1)
            {
                <div class="card-footer bg-white d-flex justify-content-between align-items-center py-2">
                    @if (ViewBag.TrangCBD > 1)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@(ViewBag.TrangCBD - 1)&trangDangLam=@ViewBag.TrangDL&trangHoanThanh=@ViewBag.TrangHT&trangHuyBo=@ViewBag.TrangHB"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                    <small class="text-muted">@ViewBag.TrangCBD / @ViewBag.TongTrangCBD</small>
                    @if (ViewBag.TrangCBD < ViewBag.TongTrangCBD)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@(ViewBag.TrangCBD + 1)&trangDangLam=@ViewBag.TrangDL&trangHoanThanh=@ViewBag.TrangHT&trangHuyBo=@ViewBag.TrangHB"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Cột Đang Làm -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">
                <i class="fas fa-spinner me-2"></i>Đang Làm
                <span class="badge bg-white text-primary float-end">@ViewBag.DangLam</span>
            </div>
            <div class="card-body p-2" style="min-height:300px">
                @foreach (var cv in dangLamList ?? new())
                {
                    @await Html.PartialAsync("_CongViecCard", cv)
                }
            </div>
            @if (ViewBag.TongTrangDL > 1)
            {
                <div class="card-footer bg-white d-flex justify-content-between align-items-center py-2">
                    @if (ViewBag.TrangDL > 1)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@ViewBag.TrangCBD&trangDangLam=@(ViewBag.TrangDL - 1)&trangHoanThanh=@ViewBag.TrangHT&trangHuyBo=@ViewBag.TrangHB"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                    <small class="text-muted">@ViewBag.TrangDL / @ViewBag.TongTrangDL</small>
                    @if (ViewBag.TrangDL < ViewBag.TongTrangDL)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@ViewBag.TrangCBD&trangDangLam=@(ViewBag.TrangDL + 1)&trangHoanThanh=@ViewBag.TrangHT&trangHuyBo=@ViewBag.TrangHB"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Cột Hoàn Thành -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-success text-white fw-semibold">
                <i class="fas fa-check-circle me-2"></i>Hoàn Thành
                <span class="badge bg-white text-success float-end">@ViewBag.HoanThanh</span>
            </div>
            <div class="card-body p-2" style="min-height:300px">
                @foreach (var cv in hoanThanhList ?? new())
                {
                    @await Html.PartialAsync("_CongViecCard", cv)
                }
            </div>
            @if (ViewBag.TongTrangHT > 1)
            {
                <div class="card-footer bg-white d-flex justify-content-between align-items-center py-2">
                    @if (ViewBag.TrangHT > 1)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@ViewBag.TrangCBD&trangDangLam=@ViewBag.TrangDL&trangHoanThanh=@(ViewBag.TrangHT - 1)&trangHuyBo=@ViewBag.TrangHB"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                    <small class="text-muted">@ViewBag.TrangHT / @ViewBag.TongTrangHT</small>
                    @if (ViewBag.TrangHT < ViewBag.TongTrangHT)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@ViewBag.TrangCBD&trangDangLam=@ViewBag.TrangDL&trangHoanThanh=@(ViewBag.TrangHT + 1)&trangHuyBo=@ViewBag.TrangHB"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Cột Huỷ Bỏ -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-danger text-white fw-semibold">
                <i class="fas fa-times-circle me-2"></i>Huỷ Bỏ
                <span class="badge bg-white text-danger float-end">@ViewBag.HuyBo</span>
            </div>
            <div class="card-body p-2" style="min-height:300px">
                @foreach (var cv in huyBoList ?? new())
                {
                    @await Html.PartialAsync("_CongViecCard", cv)
                }
            </div>
            @if (ViewBag.TongTrangHB > 1)
            {
                <div class="card-footer bg-white d-flex justify-content-between align-items-center py-2">
                    @if (ViewBag.TrangHB > 1)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@ViewBag.TrangCBD&trangDangLam=@ViewBag.TrangDL&trangHoanThanh=@ViewBag.TrangHT&trangHuyBo=@(ViewBag.TrangHB - 1)"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                    <small class="text-muted">@ViewBag.TrangHB / @ViewBag.TongTrangHB</small>
                    @if (ViewBag.TrangHB < ViewBag.TongTrangHB)
                    {
                        <a href="?@queryStr&trangChuaBatDau=@ViewBag.TrangCBD&trangDangLam=@ViewBag.TrangDL&trangHoanThanh=@ViewBag.TrangHT&trangHuyBo=@(ViewBag.TrangHB + 1)"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                    else
                    {
                        <span></span>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Thêm Công Việc -->
<div class="modal fade" id="modalThem" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-plus me-2"></i>Giao Công Việc Mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/CongViec/Them">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">
                                Tên Công Việc <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="tenCongViec" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mô Tả</label>
                            <textarea name="moTa" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                Giao Cho <span class="text-danger">*</span>
                            </label>
                            <select name="nguoiThucHien" class="form-select" required>
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach (var nd in ViewBag.DsNguoiDung)
                                {
                                    <option value="@nd.MaNguoiDung">@nd.HoTen</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Kỳ Đánh Giá</label>
                            <select name="maKy" class="form-select">
                                <option value="">-- Chọn kỳ --</option>
                                @foreach (var ky in ViewBag.DsKy)
                                {
                                    <option value="@ky.MaKy">@ky.TenKy</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Ưu Tiên</label>
                            <select name="uuTien" class="form-select">
                                <option value="Thap">Thấp</option>
                                <option value="TrungBinh" selected>Trung Bình</option>
                                <option value="Cao">Cao</option>
                                <option value="KhanCap">Khẩn Cấp</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Ngày Bắt Đầu</label>
                            <input type="date" name="ngayBatDau" id="themNgayBD"
                                   class="form-control"
                                   onchange="capNhatNgayMinKetThuc('themNgayBD','themHanHT')" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Hạn Hoàn Thành</label>
                            <input type="date" name="hanHoanThanh" id="themHanHT"
                                   class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Ghi Chú</label>
                            <textarea name="ghiChu" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Giao Việc
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa Công Việc -->
<div class="modal fade" id="modalSua" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">
                    <i class="fas fa-edit me-2"></i>Cập Nhật Công Việc
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/CongViec/CapNhat">
                <div class="modal-body">
                    <input type="hidden" name="maCongViec" id="suaMaCv" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Tên Công Việc</label>
                            <input type="text" name="tenCongViec" id="suaTenCv"
                                   class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mô Tả</label>
                            <textarea name="moTa" id="suaMoTaCv"
                                      class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Người Thực Hiện</label>
                            <select name="nguoiThucHien" id="suaNguoiTH" class="form-select">
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach (var nd in ViewBag.DsNguoiDung)
                                {
                                    <option value="@nd.MaNguoiDung">@nd.HoTen</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Trạng Thái</label>
                            <select name="trangThai" id="suaTrangThai" class="form-select">
                                <option value="ChuaBatDau">Chưa Bắt Đầu</option>
                                <option value="DangLam">Đang Làm</option>
                                <option value="HoanThanh">Hoàn Thành</option>
                                <option value="HuyBo">Huỷ Bỏ</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Ưu Tiên</label>
                            <select name="uuTien" id="suaUuTien" class="form-select">
                                <option value="Thap">Thấp</option>
                                <option value="TrungBinh">Trung Bình</option>
                                <option value="Cao">Cao</option>
                                <option value="KhanCap">Khẩn Cấp</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Kỳ Đánh Giá</label>
                            <select name="maKy" id="suaMaKy" class="form-select">
                                <option value="">-- Không có --</option>
                                @foreach (var ky in ViewBag.DsKy)
                                {
                                    <option value="@ky.MaKy">@ky.TenKy</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Ngày Bắt Đầu</label>
                            <input type="date" name="ngayBatDau" id="suaNgayBD"
                                   class="form-control"
                                   onchange="capNhatNgayMinKetThuc('suaNgayBD','suaHanHT')" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Hạn Hoàn Thành</label>
                            <input type="date" name="hanHoanThanh" id="suaHanHT"
                                   class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Ghi Chú</label>
                            <textarea name="ghiChu" id="suaGhiChu"
                                      class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save me-1"></i>Cập Nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Khong cho chon ngay ket thuc truoc ngay bat dau
        function capNhatNgayMinKetThuc(idBatDau, idKetThuc) {
            const ngayBD = document.getElementById(idBatDau).value;
            const inputKT = document.getElementById(idKetThuc);
            if (ngayBD) {
                inputKT.min = ngayBD;
                if (inputKT.value && inputKT.value < ngayBD)
                    inputKT.value = ngayBD;
            }
        }

        function suaCongViec(id) {
            fetch('/CongViec/GetById?id=' + id)
                .then(r => r.json())
                .then(data => {
                    document.getElementById('suaMaCv').value = data.maCongViec;
                    document.getElementById('suaTenCv').value = data.tenCongViec;
                    document.getElementById('suaMoTaCv').value = data.moTa || '';
                    document.getElementById('suaNguoiTH').value = data.nguoiThucHien || '';
                    document.getElementById('suaTrangThai').value = data.trangThai;
                    document.getElementById('suaUuTien').value = data.uuTien;
                    document.getElementById('suaMaKy').value = data.maKy || '';
                    document.getElementById('suaNgayBD').value = data.ngayBatDau || '';
                    document.getElementById('suaHanHT').value = data.hanHoanThanh || '';
                    document.getElementById('suaGhiChu').value = data.ghiChu || '';

                    // Set min cho han hoan thanh
                    if (data.ngayBatDau)
                        document.getElementById('suaHanHT').min = data.ngayBatDau;

                    new bootstrap.Modal(document.getElementById('modalSua')).show();
                });
        }

        function capNhatTienDo(id, tienDo) {
            fetch('/CongViec/CapNhatTienDo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&tienDo=${tienDo}`
            }).then(r => r.json()).then(data => {
                if (data.success) location.reload();
            });
        }
    </script>
}