@model QuanLyDanhGiaCongViec.Models.CongViec

@{
    var mauUuTien = Model.UuTien switch
    {
        "KhanCap" => "danger",
        "Cao" => "warning",
        "TrungBinh" => "primary",
        _ => "secondary"
    };
    string tenUuTien = Model.UuTien switch
    {
        "KhanCap" => "Khẩn Cấp",
        "Cao" => "Cao",
        "TrungBinh" => "Trung Bình",
        _ => "Thấp"
    };
    bool quaHan = Model.HanHoanThanh.HasValue
               && Model.HanHoanThanh.Value < DateOnly.FromDateTime(DateTime.Now)
               && Model.TrangThai != "HoanThanh";
}

<div class="card border-0 shadow-sm mb-2">
    <div class="card-body p-3">

        <!-- Tiêu đề + ưu tiên -->
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="fw-semibold small" style="max-width:160px;line-height:1.3">
                @Model.TenCongViec
            </div>
            <span class="badge bg-@mauUuTien" style="font-size:10px">@tenUuTien</span>
        </div>

        <!-- Người thực hiện -->
        <div class="text-muted small mb-2">
            <i class="fas fa-user me-1"></i>
            @(Model.NguoiDungThucHien?.HoTen ?? "Chưa phân công")
        </div>

        <!-- Hạn hoàn thành -->
        @if (Model.HanHoanThanh.HasValue)
            @if (Model.HanHoanThanh.HasValue)
            {
                @if (Model.TrangThai == "HoanThanh" && Model.NgayHoanThanh.HasValue)
                {
                    int soNgayTreHan = Model.NgayHoanThanh.Value.DayNumber
                    - Model.HanHoanThanh.Value.DayNumber;
                    @if (soNgayTreHan > 0)
                    {
                        <div class="small text-danger mb-2">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            Trễ <strong>@soNgayTreHan ngày</strong>
                            (HT: @Model.NgayHoanThanh.Value.ToString("dd/MM/yyyy"))
                        </div>
                    }
                    else
                    {
                        <div class="small text-success mb-2">
                            <i class="fas fa-check-circle me-1"></i>
                            Đúng hạn (@Model.NgayHoanThanh.Value.ToString("dd/MM/yyyy"))
                        </div>
                    }
                }
                else
                {
                    int soNgay = Model.HanHoanThanh.Value.DayNumber
                    - DateOnly.FromDateTime(DateTime.Now).DayNumber;
                    @if (soNgay < 0)
                    {
                        <div class="small text-danger fw-semibold mb-2">
                            <i class="fas fa-calendar me-1"></i>
                            Hạn: @Model.HanHoanThanh.Value.ToString("dd/MM/yyyy")
                            <span class="badge bg-danger">Quá @(Math.Abs(soNgay)) ngày</span>
                        </div>
                    }
                    else
                    {
                        <div class="small @(soNgay <= 3 ? "text-warning fw-semibold" : "text-muted") mb-2">
                            <i class="fas fa-calendar me-1"></i>
                            Hạn: @Model.HanHoanThanh.Value.ToString("dd/MM/yyyy")
                            @if (soNgay == 0)
                            {
                                <span class="badge bg-warning text-dark">Hôm nay</span>
                            }
                            else if (soNgay <= 3)
                            {
                                <span class="badge bg-warning text-dark">Còn @soNgay ngày</span>
                            }
                        </div>
                    }
                }
            }

        <!-- Thanh tiến độ -->
        <div class="mb-2">
            <div class="d-flex justify-content-between small text-muted mb-1">
                <span>Tiến độ</span>
                <span>@Model.TienDo%</span>
            </div>
            <div class="progress" style="height:6px">
                <div class="progress-bar bg-@(Model.TienDo == 100 ? "success" : "primary")"
                     style="width:@Model.TienDo%"></div>
            </div>
        </div>

        <!-- Cập nhật nhanh tiến độ -->
        <div class="d-flex gap-1 mb-2">
            @foreach (var pct in new[] { 25, 50, 75, 100 })
            {
                <button class="btn btn-outline-secondary flex-fill"
                        style="font-size:10px;padding:2px"
                        onclick="capNhatTienDo(@Model.MaCongViec, @pct)">
                    @pct%
                </button>
            }
        </div>

        <!-- Nút hành động -->
        <div class="d-flex gap-1">
            <a href="/CongViec/ChiTiet/@Model.MaCongViec"
               class="btn btn-sm btn-outline-info flex-fill" title="Xem chi tiết">
                <i class="fas fa-eye"></i>
            </a>
            <button class="btn btn-sm btn-outline-primary flex-fill"
                    onclick="suaCongViec(@Model.MaCongViec)" title="Chỉnh sửa">
                <i class="fas fa-edit"></i>
            </button>
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <form method="post" action="/CongViec/Xoa" class="flex-fill"
                      onsubmit="return confirm('Xoá công việc này?')">
                    <input type="hidden" name="id" value="@Model.MaCongViec" />
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                            title="Xoá">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
            }
        </div>
    </div>
</div>