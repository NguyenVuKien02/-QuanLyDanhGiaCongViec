@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h4 class="fw-bold">
            <i class="fas fa-home me-2 text-primary"></i>
            Xin chao, @ViewBag.HoTen 👋
        </h4>
        <p class="text-muted">
            Vai tro: <span class="badge bg-primary">@ViewBag.VaiTro</span>
            &nbsp;|&nbsp; @DateTime.Now.ToString("dddd, dd/MM/yyyy")
        </p>
    </div>
</div>

<!-- The cards -->
<div class="row g-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fas fa-tasks fa-2x text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Cong Viec Dang Lam</div>
                    <div class="fs-4 fw-bold">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fas fa-chart-bar fa-2x text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">KPI Thang Nay</div>
                    <div class="fs-4 fw-bold">0%</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fas fa-bullseye fa-2x text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">OKR Tien Do</div>
                    <div class="fs-4 fw-bold">0%</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="fas fa-bell fa-2x text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Thong Bao Moi</div>
                    <div class="fs-4 fw-bold">0</div>
                </div>
            </div>
        </div>
    </div>
</div>