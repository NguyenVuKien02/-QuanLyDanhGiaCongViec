@{
    ViewData["Title"] = "Chi Tiet Phieu Danh Gia";
    var phieu = ViewBag.Phieu as QuanLyDanhGiaCongViec.Models.PhieuDanhGia;
    var dsKPI = ViewBag.DsKPI as List<QuanLyDanhGiaCongViec.Models.KPINguoiDung>;
    var dsOKR = ViewBag.DsOKR as List<QuanLyDanhGiaCongViec.Models.MucTieuOKR>;
    var vaiTro = ViewBag.VaiTro as string;
    int ndHT = ViewBag.NguoiDungHT;
    bool laNguoiDuocDG = phieu?.MaNguoiDuocDG == ndHT;
    bool laNguoiDanhGia = vaiTro == "Admin" || vaiTro == "Manager";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="fas fa-star me-2 text-primary"></i>
        Phieu Danh Gia — @phieu?.NguoiDuocDanhGia?.HoTen
    </h5>
    <a href="/DanhGia/Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Quay Lai
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Thong tin tong quan phieu -->
<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Thong Tin Phieu</h6>
                <table class="table table-sm table-borderless">
                    <tr>
                        <td class="text-muted" style="width:160px">Nhan Vien:</td>
                        <td class="fw-semibold">@phieu?.NguoiDuocDanhGia?.HoTen</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Nguoi Danh Gia:</td>
                        <td>@phieu?.NguoiDanhGia?.HoTen</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Ky Danh Gia:</td>
                        <td>@phieu?.KyDanhGia?.TenKy</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Trang Thai:</td>
                        <td>
                            @{
                                string mauTT = phieu?.TrangThai switch
                                {
                                    "DaDuyet" => "success",
                                    "DaGui" => "warning",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@mauTT">@phieu?.TrangThai</span>
                        </td>
                    </tr>
                    @if (phieu?.NgayDuyet != null)
                    {
                        <tr>
                            <td class="text-muted">Ngay Duyet:</td>
                            <td>@phieu.NgayDuyet?.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body d-flex flex-column justify-content-center">
                @if (phieu?.TrangThai == "DaDuyet")
                {
                    string mauXL = phieu.XepLoai switch
                    {
                        "XuatSac" => "success",
                        "Tot" => "primary",
                        "TrungBinh" => "warning",
                        "Yeu" => "danger",
                        _ => "secondary"
                    };
                    <div class="fs-1 fw-bold text-@mauXL">@phieu.DiemTongHop%</div>
                    <span class="badge bg-@mauXL fs-6 mt-2">@phieu.XepLoai</span>
                    <div class="row mt-3 g-2">
                        <div class="col-4">
                            <div class="small text-muted">KPI</div>
                            <div class="fw-bold">@phieu.DiemKPI%</div>
                        </div>
                        <div class="col-4">
                            <div class="small text-muted">OKR</div>
                            <div class="fw-bold">@phieu.DiemOKR%</div>
                        </div>
                        <div class="col-4">
                            <div class="small text-muted">Nang Luc</div>
                            <div class="fw-bold">@phieu.DiemNangLuc/10</div>
                        </div>
                    </div>
                }
                else
                {
                    <i class="fas fa-clock fa-3x text-muted mb-2"></i>
                    <p class="text-muted small">Chua co ket qua</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- KPI -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">
        <i class="fas fa-chart-bar me-2 text-primary"></i>Ket Qua KPI
    </div>
    <div class="card-body p-0">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Chi Tieu</th>
                    <th>Muc Tieu</th>
                    <th>Thuc Te</th>
                    <th style="width:200px">Tien Do</th>
                </tr>
            </thead>
            <tbody>
                @if (dsKPI != null && dsKPI.Count > 0)
                {
                    foreach (var kpi in dsKPI)
                    {
                        double tiLe = kpi.GiaTriMucTieu > 0
                        ? Math.Min(Math.Round((kpi.GiaTriThucTe / kpi.GiaTriMucTieu) * 100, 1), 100)
                        : 0;
                        string mau = tiLe >= 100 ? "success" : tiLe >= 70 ? "primary"
                        : tiLe >= 50 ? "warning" : "danger";
                        <tr>
                            <td class="ps-3">@kpi.ChiTieuKPI?.TenKPI</td>
                            <td>@kpi.GiaTriMucTieu @kpi.ChiTieuKPI?.DonVi</td>
                            <td>@kpi.GiaTriThucTe @kpi.ChiTieuKPI?.DonVi</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:6px">
                                        <div class="progress-bar bg-@mau"
                                             style="width:@tiLe%"></div>
                                    </div>
                                    <span class="small text-@mau fw-bold">@tiLe%</span>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-3">
                            Khong co du lieu KPI trong ky nay
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- OKR -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">
        <i class="fas fa-bullseye me-2 text-warning"></i>Tien Do OKR
    </div>
    <div class="card-body">
        @if (dsOKR != null && dsOKR.Count > 0)
        {
            foreach (var okr in dsOKR)
            {
                string mauOKR = okr.TienDo >= 100 ? "success"
                : okr.TienDo >= 60 ? "primary"
                : okr.TienDo >= 30 ? "warning" : "danger";
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="fw-semibold small">@okr.TieuDe</span>
                        <span class="small text-@mauOKR fw-bold">@okr.TienDo%</span>
                    </div>
                    <div class="progress" style="height:8px">
                        <div class="progress-bar bg-@mauOKR"
                             style="width:@okr.TienDo%"></div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted text-center mb-0">Khong co OKR trong ky nay</p>
        }
    </div>
</div>

<!-- Danh gia nang luc -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">
        <i class="fas fa-user-check me-2 text-success"></i>Danh Gia Nang Luc
    </div>
    <div class="card-body">
        @if (laNguoiDuocDG && phieu?.TrangThai == "NhapLieu")
        {
            <!-- Form tu danh gia -->
            <form method="post" action="/DanhGia/TuDanhGia">
                <input type="hidden" name="maPhieu" value="@phieu.MaPhieu" />
                @foreach (var nhom in ViewBag.NhomNangLuc)
                {
                    <h6 class="fw-bold text-primary mt-3 mb-2">@nhom.Key</h6>
                    @foreach (var ct in nhom)
                    {
                        <div class="row align-items-center mb-2">
                            <div class="col-md-5 small fw-semibold">
                                @ct.NangLuc?.TenNangLuc
                                <span class="text-muted">(max @ct.NangLuc?.DiemToiDa)</span>
                            </div>
                            <div class="col-md-4">
                                <input type="range" name="self_@ct.MaChiTiet"
                                       class="form-range" min="0"
                                       max="@ct.NangLuc?.DiemToiDa" step="0.5"
                                       value="@(ct.DiemTuDanhGia ?? 0)"
                                       oninput="this.nextElementSibling.value=this.value" />
                            </div>
                            <div class="col-md-1">
                                <output class="fw-bold text-primary">
                                    @(ct.DiemTuDanhGia ?? 0)
                                </output>
                            </div>
                        </div>
                    }
                }
                <div class="mb-3 mt-3">
                    <label class="form-label fw-semibold">Nhan Xet Ban Than</label>
                    <textarea name="nhanXetBanThan" class="form-control" rows="3"
                              placeholder="Tu nhan xet ket qua lam viec cua ban...">@phieu?.NhanXetBanThan</textarea>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-paper-plane me-1"></i>Nop Phieu Tu Danh Gia
                </button>
            </form>
        }
        else if (laNguoiDanhGia && phieu?.TrangThai == "DaGui")
        {
            <!-- Form quan ly cham diem -->
            <form method="post" action="/DanhGia/ChamDiem">
                <input type="hidden" name="maPhieu" value="@phieu.MaPhieu" />
                @foreach (var nhom in ViewBag.NhomNangLuc)
                {
                    <h6 class="fw-bold text-primary mt-3 mb-2">@nhom.Key</h6>
                    @foreach (var ct in nhom)
                    {
                        <div class="row align-items-center mb-2">
                            <div class="col-md-4 small fw-semibold">
                                @ct.NangLuc?.TenNangLuc
                            </div>
                            <div class="col-md-2 text-center">
                                <span class="badge bg-info">
                                    Tu DG: @(ct.DiemTuDanhGia?.ToString("0.#") ?? "—")
                                </span>
                            </div>
                            <div class="col-md-4">
                                <input type="range" name="mgr_@ct.MaChiTiet"
                                       class="form-range" min="0"
                                       max="@ct.NangLuc?.DiemToiDa" step="0.5"
                                       value="@(ct.DiemQuanLyCham ?? ct.DiemTuDanhGia ?? 0)"
                                       oninput="this.nextElementSibling.value=this.value" />
                            </div>
                            <div class="col-md-1">
                                <output class="fw-bold text-success">
                                    @(ct.DiemQuanLyCham ?? ct.DiemTuDanhGia ?? 0)
                                </output>
                            </div>
                        </div>
                    }
                }
                <div class="mb-3 mt-3">
                    <div class="mb-2">
                        <label class="form-label fw-semibold text-muted">
                            Nhan Xet Cua Nhan Vien:
                        </label>
                        <p class="border rounded p-2 bg-light small">
                            @(phieu?.NhanXetBanThan ?? "Khong co nhan xet")
                        </p>
                    </div>
                    <label class="form-label fw-semibold">Nhan Xet Quan Ly</label>
                    <textarea name="nhanXetQuanLy" class="form-control" rows="3"
                              placeholder="Nhan xet ve ket qua lam viec...">@phieu?.NhanXetQuanLy</textarea>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-check-circle me-1"></i>Duyet Va Cham Diem
                </button>
            </form>
        }
        else
        {
            <!-- Chi xem ket qua -->
            @foreach (var nhom in ViewBag.NhomNangLuc)
            {
                <h6 class="fw-bold text-primary mt-3 mb-2">@nhom.Key</h6>
                <table class="table table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Tieu Chi</th>
                            <th>Tu Danh Gia</th>
                            <th>Quan Ly Cham</th>
                            <th>Chinh Thuc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ct in nhom)
                        {
                            <tr>
                                <td>@ct.NangLuc?.TenNangLuc</td>
                                <td>@(ct.DiemTuDanhGia?.ToString("0.#") ?? "—")</td>
                                <td>@(ct.DiemQuanLyCham?.ToString("0.#") ?? "—")</td>
                                <td class="fw-bold text-primary">
                                    @(ct.DiemChinhThuc?.ToString("0.#") ?? "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            @if (phieu?.NhanXetBanThan != null)
            {
                <div class="mt-3">
                    <label class="fw-semibold text-muted small">Nhan Xet Ban Than:</label>
                    <p class="border rounded p-2 bg-light small">@phieu.NhanXetBanThan</p>
                </div>
            }
            @if (phieu?.NhanXetQuanLy != null)
            {
                <div class="mt-2">
                    <label class="fw-semibold text-muted small">Nhan Xet Quan Ly:</label>
                    <p class="border rounded p-2 bg-light small">@phieu.NhanXetQuanLy</p>
                </div>
            }
        }
    </div>
</div>
